generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IntelSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BriefCardType {
  EXECUTIVE_SUMMARY
  VULNERABILITY
  THREAT_ACTIVITY
  RECOMMENDATION
}

enum ConfidenceLevel {
  LOW
  MEDIUM
  HIGH
}

model FeedSource {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  baseUrl       String?
  isActive      Boolean        @default(true)
  pollingMins   Int            @default(60)
  createdAt     DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @db.Timestamptz(6)
  intelItems    IntelItem[]
  subscriptions Subscription[]

  @@index([isActive])
}

model IntelItem {
  id              String         @id @default(cuid())
  feedSourceId    String
  externalId      String
  title           String
  summary         String
  sourceUrl       String?
  severity        IntelSeverity
  publishedAt     DateTime       @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @db.Timestamptz(6)
  feedSource      FeedSource     @relation(fields: [feedSourceId], references: [id], onDelete: Cascade)
  vulnerabilities Vulnerability[]

  @@unique([feedSourceId, externalId])
  @@index([severity, publishedAt])
  @@index([publishedAt])
}

model Vulnerability {
  id           String     @id @default(cuid())
  intelItemId  String
  cveId        String     @unique
  vendor       String?
  product      String?
  cvssScore    Decimal?   @db.Decimal(4, 1)
  exploited    Boolean    @default(false)
  patched      Boolean    @default(false)
  publishedAt  DateTime?  @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @db.Timestamptz(6)
  intelItem    IntelItem  @relation(fields: [intelItemId], references: [id], onDelete: Cascade)

  @@index([intelItemId])
  @@index([exploited, patched])
}

model DailyBrief {
  id         String      @id @default(cuid())
  briefDate  DateTime    @unique @db.Date
  title      String
  createdAt  DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime    @updatedAt @db.Timestamptz(6)
  briefCards BriefCard[]

  @@index([createdAt])
}

model BriefCard {
  id              String          @id @default(cuid())
  dailyBriefId    String
  cardType        BriefCardType
  title           String
  summaryBullets  Json
  whyItMatters    String
  suggestedAction String?
  confidence      ConfidenceLevel
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @db.Timestamptz(6)
  dailyBrief      DailyBrief      @relation(fields: [dailyBriefId], references: [id], onDelete: Cascade)

  @@index([dailyBriefId, sortOrder])
  @@index([cardType])
}

model Subscription {
  id             String         @id @default(cuid())
  feedSourceId   String
  subscriberKey  String
  channel        String
  endpoint       String
  isActive       Boolean        @default(true)
  lastDeliveredAt DateTime?     @db.Timestamptz(6)
  createdAt      DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @db.Timestamptz(6)
  feedSource     FeedSource     @relation(fields: [feedSourceId], references: [id], onDelete: Cascade)
  userPreference UserPreference?

  @@unique([feedSourceId, subscriberKey, channel])
  @@index([subscriberKey])
  @@index([isActive])
}

model UserPreference {
  id                    String        @id @default(cuid())
  subscriptionId        String        @unique
  timezone              String        @default("UTC")
  digestHourUtc         Int           @default(8)
  minimumSeverity       IntelSeverity @default(MEDIUM)
  includeRecommendations Boolean      @default(true)
  createdAt             DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime      @updatedAt @db.Timestamptz(6)
  subscription          Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([minimumSeverity, digestHourUtc])
}
